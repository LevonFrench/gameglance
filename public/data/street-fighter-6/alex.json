  "combosList": [
    {
      "id": "alex_combo_1",
      "name": "When close enough a second 2LP or 5LP can be added. Damage is then 1130/1230.",
      "input": "2LK/2LP/5LP ~ 2LP/5LP > 236LP"
    },
    {
      "id": "alex_combo_2",
      "name": "Other light starters work as well",
      "input": "5LP ~ 5LP ~ 5LP  > 623HK"
    },
    {
      "id": "alex_combo_3",
      "name": "Ending in 623HK purely for damage still gives good oki in the corner. If you want to spend super 236LP/236PP allow cancels into SA3 and 236PP allows cancels into SA2.",
      "input": "2HP > 2PP > LP ~ HP, 5LK > 623HK/623KK/236LP/236PP"
    },
    {
      "id": "alex_combo_4",
      "name": "Simple counter hit combo from overhead. Also works with 5LP when close enough but 2LP is more consistent.",
      "input": "6MP, 2LP > 623HK"
    },
    {
      "id": "alex_combo_5",
      "name": "Seems like the optimal meterless midscreen punish using 2HP",
      "input": "2HP > 2PP > HP, 623HK"
    },
    {
      "id": "alex_combo_6",
      "name": "Sideswap. Link with the 5MP is easier and works at all ranges. At longer ranges the 2HP whiffs",
      "input": "236HP, 5MP/2HP > DR ~ 2HP > 236HP ~ 63214P"
    },
    {
      "id": "alex_combo_7",
      "name": "Holding forward removes sideswap and gives extra damage. Same combo as before. Less drive efficient.",
      "input": "236HP, 5MP/2HP > DR ~ 2HP > 236HP ~ 63214PP ( > 6 )"
    },
    {
      "id": "alex_combo_8",
      "name": "Standard Combo",
      "input": "236HP, 5MP/2HP > DR ~ 2HP > 236HP ~ 63214PP ~ SA2 (PP)"
    }
  ]
}