  "combosList": [
    {
      "id": "sagat_combo_1",
      "name": "Better corner carry and oki than the 623MP ender. If starting with a Drive Rush light, can use any 3-light chain ending with 5LP for more hitconfirm time.",
      "input": "2LP ~ 2LP > 236LK"
    },
    {
      "id": "sagat_combo_2",
      "name": "Nexus confirm from 2 lights (must cancel from 5LP). Use ~6LK for grounded +3 reset or on crouchers. Use ~6MK for knockdown against standing opponents with better oki than MP Uppercut.",
      "input": "5LP ~ 5LP > 214LK~(6LK/6MK)"
    },
    {
      "id": "sagat_combo_3",
      "name": "Low starter hitconfirm into a knockdown. This specific sequence works from slightly farther out than any chain involving 2LP, but any 3-light chain can work from the closest distance.",
      "input": "2LK ~ 5LP ~ 5LP > 623MP"
    },
    {
      "id": "sagat_combo_4",
      "name": "Decent damage from a light confirm, expensive but worthwhile to kill or improve your positioning. Can start from either LP, but must link into DR~2LP. * requires Sweet Spot connect (auto-timed).",
      "input": "LP > DRC~2LP, 4HP > 236HK*, 623LP"
    },
    {
      "id": "sagat_combo_5",
      "name": "Standard Combo",
      "input": "CH 2LP, 5MP, 5LP > 623MP"
    },
    {
      "id": "sagat_combo_6",
      "name": "Better corner carry than MP Uppercut ender.",
      "input": "CH 2LP, 2MP > 236HK"
    },
    {
      "id": "sagat_combo_7",
      "name": "Better damage than HK Knee route with the option to spend meter for even more.",
      "input": "CH 2LP, 2MP >  623HP ( > SA3)"
    },
    {
      "id": "sagat_combo_8",
      "name": "5LP and 2LP are interchangeable, but 5LP has more range.",
      "input": "CH 6LK, 5LP > 623MP"
    }
  ]
